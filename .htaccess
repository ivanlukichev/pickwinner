DirectoryIndex index.html
Options -Indexes -MultiViews

ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Normalize www to the canonical apex host.
  RewriteCond %{HTTP_HOST} ^www\.pickwinner\.tools$ [NC]
  RewriteRule ^ https://pickwinner.tools%{REQUEST_URI} [R=301,L]

  # Redirect direct index files to clean URLs.
  RewriteRule ^index\.html$ / [R=301,L]
  RewriteRule ^tools/index\.html$ /tools/ [R=301,L]
  RewriteRule ^guides/index\.html$ /guides/ [R=301,L]
  RewriteRule ^randomness/index\.html$ /randomness/ [R=301,L]
  RewriteRule ^spin-the-wheel/?$ /tools/spin-the-wheel.html [R=301,L]

  # Respect Cloudflare / proxy HTTPS headers to avoid redirect loops.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteCond %{HTTP:CF-Visitor} !"scheme":"https" [NC]
  RewriteRule ^ https://pickwinner.tools%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "camera=(), geolocation=(), microphone=()"

  <FilesMatch "\.(html?|xml|txt)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|gif|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/plain "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 7 days"
  ExpiresByType image/png "access plus 7 days"
  ExpiresByType image/jpeg "access plus 7 days"
  ExpiresByType image/webp "access plus 7 days"
  ExpiresByType image/gif "access plus 7 days"
  ExpiresByType image/x-icon "access plus 7 days"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json application/xml image/svg+xml
</IfModule>
