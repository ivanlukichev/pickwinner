/guides/
  Cache-Control: public, max-age=0, must-revalidate

/guides/*.html
  Cache-Control: public, max-age=0, must-revalidate

/randomness/
  Cache-Control: public, max-age=0, must-revalidate

/random-picker/
  Cache-Control: public, max-age=0, must-revalidate

/raffle-picker/
  Cache-Control: public, max-age=0, must-revalidate

/giveaway-picker/
  Cache-Control: public, max-age=0, must-revalidate

/random-decision-maker/
  Cache-Control: public, max-age=0, must-revalidate

/online-wheel-spinner/
  Cache-Control: public, max-age=0, must-revalidate

/*.xml
  Cache-Control: public, max-age=0, must-revalidate

/*.txt
  Cache-Control: public, max-age=0, must-revalidate

/css/*
  Cache-Control: public, max-age=604800

/js/*
  Cache-Control: public, max-age=604800

/img/*
  Cache-Control: public, max-age=604800

/*.ico
  Cache-Control: public, max-age=604800
