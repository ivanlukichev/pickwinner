{
  "manifest_version": 3,
  "name": "PickWinner Tools Coin Flip",
  "short_name": "Coin Flip",
  "version": "1.0.0",
  "description": "Flip a simple virtual coin from the browser toolbar.",
  "homepage_url": "https://pickwinner.tools/",
  "action": {
    "default_title": "Coin Flip",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "coinflip@pickwinner.tools",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
